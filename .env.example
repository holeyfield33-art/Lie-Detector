# Lie Detector — Environment Variables
# Copy this file to .env and fill in your credentials.
# .env is git-ignored and will never be committed.

# === Anthropic (default provider) ===
# Required for --provider anthropic (the default).
# The SDK also resolves `ant auth login` stored profiles automatically.
ANTHROPIC_API_KEY=sk-ant-...

# === OpenAI-compatible (Featherless, OpenAI, etc.) ===
# Required for --provider openai.
# Use either OPENAI_API_KEY or FEATHERLESS_API_KEY (OPENAI_API_KEY takes priority).
OPENAI_API_KEY=your-featherless-or-openai-key-here
# FEATHERLESS_API_KEY=your-featherless-key-here

# Base URL for OpenAI-compatible providers.
# - Featherless:  https://api.featherless.ai/v1
# - OpenAI:       https://api.openai.com/v1  (default if unset)
# - OpenRouter:   https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.featherless.ai/v1

# === Optional: proxy/CA for install phase ===
# Set LIEDETECTOR_INSTALL_HOST_NETWORK=1 if the install container needs
# to reach a loopback egress proxy.
# LIEDETECTOR_INSTALL_HOST_NETWORK=1
# HTTPS_PROXY=http://localhost:8888
# LIEDETECTOR_CA_BUNDLE=/path/to/ca-bundle.crt